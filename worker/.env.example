# ============================================
# Avatar IA Worker — Variables d'environnement
# ============================================
# Ce fichier est stocké sur la VM GPU (pas sur GitHub)
# Copier en .env et remplir les valeurs

# Token d'authentification (doit correspondre à GPU_WORKER_TOKEN du frontend)
WORKER_TOKEN=

# Chemins des modèles IA (créés par setup.sh)
HUNYUAN_MODEL_PATH=/root/avatar-data/models/hunyuan
FISH_MODEL_PATH=/root/avatar-data/models/fish-audio

# Chemins des assets (photos de référence + échantillon vocal)
PHOTOS_PATH=/root/avatar-data/photos
VOICE_PATH=/root/avatar-data/voice

# Dossier de sortie des vidéos générées
OUTPUT_PATH=/root/avatar-data/outputs
