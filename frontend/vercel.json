{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["cdg1"],
  "crons": [
    {
      "path": "/api/vast/auto-stop",
      "schedule": "*/10 * * * *"
    }
  ],
  "functions": {
    "app/api/gpu/download/route.ts": {
      "maxDuration": 30
    },
    "app/api/gpu/generate/route.ts": {
      "maxDuration": 30
    },
    "app/api/canva/upload/route.ts": {
      "maxDuration": 60
    },
    "app/api/r2/upload/route.ts": {
      "maxDuration": 60
    },
    "app/api/ai/script/route.ts": {
      "maxDuration": 30
    }
  }
}
