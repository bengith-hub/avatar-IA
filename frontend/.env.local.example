# ============================================
# Avatar IA — Variables d'environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs
# Sur Vercel : Settings → Environment Variables

# --- Auth (REQUIS) ---
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_USERNAME=benjamin
# Générer avec : echo -n "votre_mot_de_passe" | shasum -a 256
AUTH_PASSWORD_HASH=

# --- Vast.ai (REQUIS) ---
# Dashboard Vast.ai → Account → API Key
VAST_API_KEY=
# ID de votre instance (visible dans le dashboard ou via l'API)
VAST_INSTANCE_ID=

# --- GPU Worker (REQUIS) ---
# URL publique du worker FastAPI sur la VM (ex: http://123.45.67.89:8000)
GPU_WORKER_URL=
# Token d'auth (doit correspondre à WORKER_TOKEN dans worker/.env)
GPU_WORKER_TOKEN=

# --- Pexels (REQUIS) ---
# https://www.pexels.com/api/ → Get Started (gratuit)
PEXELS_API_KEY=

# --- Anthropic (REQUIS) ---
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- Canva Connect (OPTIONNEL — Phase 2) ---
# https://www.canva.dev → créer une app
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_ACCESS_TOKEN=

# --- Cloudflare R2 (OPTIONNEL — Phase 2) ---
# https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=avatar-videos
